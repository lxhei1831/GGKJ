/**app.wxss**/
page {
  min-height: 100vh;
  background: #eef3f8;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.page-shell {
  min-height: 100vh;
  display: block;
  background:
    radial-gradient(circle at 14% 0%, rgba(37, 99, 235, 0.13) 0%, rgba(37, 99, 235, 0) 36%),
    radial-gradient(circle at 88% 18%, rgba(14, 165, 233, 0.11) 0%, rgba(14, 165, 233, 0) 32%),
    linear-gradient(180deg, #e4efff 0%, #f7faff 44%, #eaf2fb 100%);
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.page-content {
  padding: 24rpx 28rpx 160rpx;
  box-sizing: border-box;
}

.hero-panel {
  padding: 30rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(248, 251, 255, 0.99) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.095) 0%, rgba(255, 255, 255, 0) 48%, rgba(14, 165, 233, 0.075) 100%);
  color: #111827;
  border: 1rpx solid #e5eaf3;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.05);
}

.hero-top,
.section-head,
.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.eyebrow,
.hero-panel .eyebrow {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 38rpx;
  line-height: 1.18;
  font-weight: 800;
  letter-spacing: 0;
  color: #111827;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: #64748b;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  font-size: 30rpx;
  line-height: 1.3;
  color: #111827;
  font-weight: 800;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #64748b;
}

.card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(249, 251, 254, 0.99) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.07) 0%, rgba(255, 255, 255, 0) 52%, rgba(100, 116, 139, 0.055) 100%);
  border: 1rpx solid #e5eaf3;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.035);
  box-sizing: border-box;
}

.grid-two {
  display: flex;
  flex-wrap: wrap;
  margin: 4rpx -8rpx 0;
}

.grid-item {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.grid-item-full {
  width: 100%;
}

.card-title {
  display: block;
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 750;
  color: #111827;
}

.card-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #64748b;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 850;
  color: #111827;
}

.metric-label {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #64748b;
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  line-height: 1;
  font-weight: 700;
}

.badge-high {
  color: #b42318;
  background: #fee4e2;
}

.badge-medium {
  color: #92400e;
  background: #fef3c7;
}

.badge-low {
  color: #0369a1;
  background: #e0f2fe;
}

.badge-info {
  color: #1d4ed8;
  background: #e8f0ff;
}

.primary-button,
.secondary-button,
.ghost-button {
  height: 82rpx;
  border-radius: 14rpx;
  font-size: 27rpx;
  font-weight: 750;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.primary-button {
  color: #ffffff;
  background: #2563eb;
}

.secondary-button {
  color: #1d4ed8;
  background: #e8f0ff;
}

.ghost-button {
  color: #334155;
  background: #eef2f7;
}

.input-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(248, 251, 255, 0.99) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.065) 0%, rgba(255, 255, 255, 0) 58%, rgba(14, 165, 233, 0.06) 100%);
  border: 1rpx solid #e5eaf3;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.035);
}

.field {
  margin-top: 22rpx;
}

.field:first-child {
  margin-top: 0;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #334155;
  font-weight: 700;
}

.text-input,
.text-area,
.picker-field {
  width: 100%;
  min-height: 80rpx;
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  border: 1rpx solid #dbe3ef;
  color: #111827;
  font-size: 26rpx;
  box-sizing: border-box;
}

.text-area {
  min-height: 180rpx;
  line-height: 1.5;
}

.list-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e5eaf3;
}

.list-row:last-child {
  border-bottom: 0;
}

.muted {
  color: #64748b;
}

.divider {
  height: 1rpx;
  background: #e5eaf3;
  margin: 22rpx 0;
}
