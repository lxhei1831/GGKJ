page {
  min-height: 100vh;
}

.risk-detail-page {
  padding-bottom: 72rpx;
}

.detail-hero {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(247, 250, 255, 0.99) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.095) 0%, rgba(255, 255, 255, 0) 52%, rgba(15, 23, 42, 0.06) 100%);
}

.hero-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #1d4ed8;
  background: #e8f0ff;
}

.source-note {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #475569;
  background: #eef4ff;
  border: 1rpx solid #dbeafe;
}

.stat-strip {
  display: flex;
  padding: 22rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(248, 251, 255, 0.99) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.07) 0%, rgba(255, 255, 255, 0) 62%, rgba(100, 116, 139, 0.05) 100%);
  border: 1rpx solid #e5eaf3;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.035);
}

.stat-cell {
  flex: 1;
  min-width: 0;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.stat-value {
  display: block;
  font-size: 31rpx;
  line-height: 1.25;
  font-weight: 850;
  color: #111827;
  word-break: break-word;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #64748b;
}

.guidance-row {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
}

.guidance-row:first-child {
  margin-top: 0;
}

.guidance-index {
  width: 38rpx;
  height: 38rpx;
  line-height: 38rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 21rpx;
  font-weight: 800;
  color: #ffffff;
  background: #2563eb;
  flex: none;
}

.guidance-text {
  margin-left: 16rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: #334155;
}

.detail-card {
  margin-top: 18rpx;
}

.detail-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.detail-title-block {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.rights-pill {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.3;
  color: #1d4ed8;
  background: #e8f0ff;
}

.analysis-text {
  display: block;
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: #334155;
}

.detail-block {
  margin-top: 24rpx;
}

.detail-block-title {
  display: block;
  font-size: 25rpx;
  font-weight: 800;
  color: #111827;
}

.bullet-row {
  display: flex;
  align-items: flex-start;
  margin-top: 14rpx;
}

.bullet-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 13rpx;
  border-radius: 999rpx;
  background: #2563eb;
  flex: none;
}

.bullet-dot-high {
  background: #b42318;
}

.bullet-text {
  margin-left: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #475569;
}

.source-row {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e5eaf3;
}

.source-label {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #0369a1;
  background: #e0f2fe;
  flex: none;
}

.source-name {
  flex: 1;
  min-width: 0;
  margin-left: 14rpx;
  font-size: 23rpx;
  color: #64748b;
}

.source-copy {
  margin-left: 14rpx;
  font-size: 23rpx;
  font-weight: 800;
  color: #1d4ed8;
  flex: none;
}
