<view class="page-shell">
  <view class="page-content risk-page">
    <view class="hero-panel">
      <view class="hero-top">
        <text class="eyebrow">跨境侵权风险管理</text>
        <text class="hero-badge">实时预警</text>
      </view>
      <text class="hero-title">店铺上架前，先看风险分布</text>
      <text class="hero-desc">聚合品牌词、TRO案件、图片元素和检测报告，快速定位需要先处理的商品。</text>
      <view class="hero-metrics">
        <view class="hero-metric" wx:for="{{metrics}}" wx:key="label">
          <text class="hero-metric-value">{{item.value}}</text>
          <text class="hero-metric-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view>
          <text class="section-title">快捷检测</text>
          <text class="section-subtitle">按场景进入检测模块，后续统一生成报告。</text>
        </view>
      </view>
      <view class="grid-two">
        <view class="grid-item" wx:for="{{quickActions}}" wx:key="mode">
          <view class="card action-card action-{{item.tone}}" bindtap="goDetect" data-mode="{{item.mode}}">
            <view class="action-mark"></view>
            <text class="card-title">{{item.title}}</text>
            <text class="card-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view>
          <text class="section-title">成功案例</text>
          <text class="section-subtitle">匿名脱敏展示小程序检测与律师服务协同处理的真实场景。</text>
        </view>
      </view>
      <view class="case-list">
        <view class="card case-card" wx:for="{{successCases}}" wx:key="id" bindtap="openCase" data-id="{{item.id}}">
          <view class="case-head">
            <text class="badge badge-info">{{item.tag}}</text>
          </view>
          <text class="card-title">{{item.title}}</text>
          <text class="card-desc">{{item.result}}</text>
          <view class="case-flow">
            <view class="case-step" wx:for="{{item.steps}}" wx:for-item="step" wx:key="*this">
              <text class="case-step-dot"></text>
              <text class="case-step-text">{{step}}</text>
            </view>
          </view>
          <view class="case-more">
            <text>查看详情</text>
            <text class="case-more-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

  </view>
</view>
