page {
  min-height: 100vh;
}

.risk-page {
  padding-bottom: 72rpx;
}

.hero-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #1d4ed8;
  background: #e8f0ff;
}

.hero-metrics {
  display: flex;
  margin-top: 28rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  padding-top: 24rpx;
}

.hero-metric {
  flex: 1;
}

.hero-metric-value {
  display: block;
  font-size: 34rpx;
  line-height: 1.1;
  font-weight: 850;
}

.hero-metric-label {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #64748b;
}

.action-card {
  min-height: 190rpx;
  margin-top: 0;
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(45deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 23%, rgba(255, 255, 255, 0) 76%, rgba(255, 255, 255, 0.58) 100%),
    radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.86) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.44) 0%, rgba(248, 251, 255, 0.26) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.12) 0%, rgba(255, 255, 255, 0) 50%, rgba(14, 165, 233, 0.1) 100%);
}

.action-card:active {
  transform: scale(0.98);
}

.action-mark {
  width: 44rpx;
  height: 10rpx;
  border-radius: 999rpx;
  margin-bottom: 18rpx;
  background: #2563eb;
}

.action-blue .action-mark {
  background: #3b82f6;
}

.action-amber .action-mark {
  background: #64748b;
}

.action-slate .action-mark {
  background: #475467;
}

.case-list {
  margin-top: 2rpx;
}

.case-card {
  margin-top: 18rpx;
  overflow: hidden;
  background:
    linear-gradient(45deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 23%, rgba(255, 255, 255, 0) 76%, rgba(255, 255, 255, 0.58) 100%),
    radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.86) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.44) 0%, rgba(248, 251, 255, 0.26) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(255, 255, 255, 0) 50%, rgba(16, 185, 129, 0.1) 100%);
}

.case-card:active {
  transform: scale(0.98);
}

.case-head {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.case-flow {
  display: flex;
  flex-wrap: nowrap;
  margin: 18rpx -6rpx 0;
}

.case-step {
  flex: 1;
  min-width: 0;
  min-height: 40rpx;
  padding: 0 6rpx;
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
}

.case-step-dot {
  width: 12rpx;
  height: 12rpx;
  margin: 12rpx 10rpx 0 0;
  border-radius: 999rpx;
  flex: none;
  background: #10b981;
}

.case-step-text {
  font-size: 22rpx;
  line-height: 1.35;
  color: #334155;
  white-space: nowrap;
}

.case-more {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 18rpx;
  font-size: 23rpx;
  color: #1d4ed8;
  font-weight: 750;
}

.case-more-arrow {
  margin-left: 8rpx;
  font-size: 30rpx;
  line-height: 1;
}
