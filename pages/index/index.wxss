page {
  min-height: 100vh;
}

.risk-page {
  padding-bottom: 72rpx;
}

.hero-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #1d4ed8;
  background: #e8f0ff;
}

.hero-metrics {
  display: flex;
  margin-top: 28rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  padding-top: 24rpx;
}

.hero-metric {
  flex: 1;
}

.hero-metric-value {
  display: block;
  font-size: 34rpx;
  line-height: 1.1;
  font-weight: 850;
}

.hero-metric-label {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #64748b;
}

.action-card {
  min-height: 190rpx;
  margin-top: 0;
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(45deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 23%, rgba(255, 255, 255, 0) 76%, rgba(255, 255, 255, 0.58) 100%),
    radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.86) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.44) 0%, rgba(248, 251, 255, 0.26) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.12) 0%, rgba(255, 255, 255, 0) 50%, rgba(14, 165, 233, 0.1) 100%);
}

.action-card:active {
  transform: scale(0.98);
}

.action-mark {
  width: 44rpx;
  height: 10rpx;
  border-radius: 999rpx;
  margin-bottom: 18rpx;
  background: #2563eb;
}

.action-blue .action-mark {
  background: #3b82f6;
}

.action-amber .action-mark {
  background: #64748b;
}

.action-slate .action-mark {
  background: #475467;
}

.metric-card {
  min-height: 172rpx;
  margin-top: 0;
  background:
    linear-gradient(45deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 23%, rgba(255, 255, 255, 0) 76%, rgba(255, 255, 255, 0.58) 100%),
    radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.86) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.44) 0%, rgba(248, 251, 255, 0.26) 100%),
    linear-gradient(135deg, rgba(30, 64, 175, 0.12) 0%, rgba(255, 255, 255, 0) 58%, rgba(71, 85, 105, 0.08) 100%);
}

.metric-link:active {
  transform: scale(0.98);
}

.metric-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.metric-arrow {
  font-size: 38rpx;
  line-height: 1;
  color: #98a2b3;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.risk-tag {
  margin: 0 12rpx 12rpx 0;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  color: #334155;
  background: #eef2f7;
}

.report-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.emergency-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background:
    linear-gradient(45deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 23%, rgba(255, 255, 255, 0) 76%, rgba(255, 255, 255, 0.58) 100%),
    radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.86) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.44) 0%, rgba(248, 251, 255, 0.26) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.11) 0%, rgba(255, 255, 255, 0) 55%, rgba(15, 23, 42, 0.08) 100%);
}

.compact-button {
  width: 176rpx;
  height: 72rpx;
  margin-left: 24rpx;
  flex: none;
  font-size: 25rpx;
}
