page {
  min-height: 100vh;
}

.tro-page {
  padding-bottom: 72rpx;
}

.tro-hero {
  background:
    linear-gradient(45deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 23%, rgba(255, 255, 255, 0) 76%, rgba(255, 255, 255, 0.58) 100%),
    radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.86) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.44) 0%, rgba(248, 251, 255, 0.26) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.12) 0%, rgba(255, 255, 255, 0) 52%, rgba(15, 23, 42, 0.08) 100%);
}

.tro-button {
  margin-top: 26rpx;
}

.case-result-card {
  margin-top: 24rpx;
}

.lawyer-service-card {
  background:
    linear-gradient(45deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 23%, rgba(255, 255, 255, 0) 76%, rgba(255, 255, 255, 0.58) 100%),
    radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.86) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.44) 0%, rgba(248, 251, 255, 0.26) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.12) 0%, rgba(255, 255, 255, 0) 55%, rgba(14, 165, 233, 0.1) 100%);
}

.lawyer-service-top {
  display: flex;
  align-items: center;
}

.lawyer-avatar {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 38rpx;
  font-weight: 900;
  color: #ffffff;
  background: #2563eb;
  flex: none;
}

.lawyer-service-main {
  flex: 1;
  margin-left: 20rpx;
}

.menu-arrow {
  margin-left: 16rpx;
  font-size: 44rpx;
  color: #98a2b3;
}

.lawyer-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 22rpx;
}

.lawyer-tag {
  margin: 0 12rpx 12rpx 0;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #1d4ed8;
  background: #e8f0ff;
}

.case-action {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
}

.case-action-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 13rpx;
  border-radius: 999rpx;
  background: #2563eb;
  flex: none;
}

.case-action-text {
  margin-left: 16rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: #344054;
}
