page {
  min-height: 100vh;
}

.tro-page {
  padding-bottom: 72rpx;
}

.tro-hero {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(247, 250, 255, 0.99) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.06) 0%, rgba(255, 255, 255, 0) 52%, rgba(15, 23, 42, 0.04) 100%);
}

.tro-button {
  margin-top: 26rpx;
}

.module-card {
  min-height: 188rpx;
  margin-top: 0;
}

.lawyer-service-card {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(248, 251, 255, 0.99) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.06) 0%, rgba(255, 255, 255, 0) 55%, rgba(14, 165, 233, 0.05) 100%);
}

.lawyer-service-top {
  display: flex;
  align-items: center;
}

.lawyer-avatar {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 38rpx;
  font-weight: 900;
  color: #ffffff;
  background: #2563eb;
  flex: none;
}

.lawyer-service-main {
  flex: 1;
  margin-left: 20rpx;
}

.menu-arrow {
  margin-left: 16rpx;
  font-size: 44rpx;
  color: #98a2b3;
}

.lawyer-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 22rpx;
}

.lawyer-tag {
  margin: 0 12rpx 12rpx 0;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #1d4ed8;
  background: #e8f0ff;
}

.case-action,
.check-row {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
}

.case-action-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 13rpx;
  border-radius: 999rpx;
  background: #2563eb;
  flex: none;
}

.case-action-text,
.check-text {
  margin-left: 16rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: #344054;
}

.check-box {
  width: 34rpx;
  height: 34rpx;
  margin-top: 4rpx;
  border-radius: 8rpx;
  border: 2rpx solid #99a8bd;
  background: #ffffff;
  flex: none;
}

.brand-library {
  background:
    linear-gradient(180deg, #ffffff 0%, #f8fafc 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.04) 0%, rgba(255, 255, 255, 0) 62%, rgba(100, 116, 139, 0.035) 100%);
}

.library-button {
  margin-top: 22rpx;
}
