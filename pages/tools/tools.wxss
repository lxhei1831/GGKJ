page {
  min-height: 100vh;
}

.tools-page {
  padding-bottom: 72rpx;
}

.tools-hero {
  background:
    linear-gradient(45deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 23%, rgba(255, 255, 255, 0) 76%, rgba(255, 255, 255, 0.58) 100%),
    radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.86) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.44) 0%, rgba(248, 251, 255, 0.26) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.12) 0%, rgba(255, 255, 255, 0) 55%, rgba(14, 165, 233, 0.1) 100%);
}

.tools-grid {
  margin-top: 10rpx;
}

.tools-grid .grid-item {
  width: 50%;
  padding: 8rpx;
}

.tool-card {
  min-height: 190rpx;
  margin-top: 0;
  padding: 22rpx;
  background:
    linear-gradient(45deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 23%, rgba(255, 255, 255, 0) 76%, rgba(255, 255, 255, 0.58) 100%),
    radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.86) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.44) 0%, rgba(248, 251, 255, 0.26) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(255, 255, 255, 0) 60%, rgba(100, 116, 139, 0.08) 100%);
}

.tool-card:active {
  transform: scale(0.98);
}

.tool-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 12rpx;
  margin-bottom: 18rpx;
  text-align: center;
  font-size: 23rpx;
  font-weight: 850;
  color: #ffffff;
  background: #1d4ed8;
}

.template-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eef2f6;
}

.template-row:last-child {
  border-bottom: 0;
}

.mini-button {
  width: 132rpx;
  height: 66rpx;
  margin-left: 20rpx;
  flex: none;
  font-size: 24rpx;
}

.assistant-card {
  background:
    linear-gradient(45deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 23%, rgba(255, 255, 255, 0) 76%, rgba(255, 255, 255, 0.58) 100%),
    radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.86) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.44) 0%, rgba(248, 251, 255, 0.26) 100%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(255, 255, 255, 0) 62%, rgba(14, 165, 233, 0.09) 100%);
}

.assistant-button {
  margin-top: 22rpx;
}
